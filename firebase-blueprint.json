{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A fashion item for sale in the store",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["Tracksuits", "Trousers", "T-Shirts"] },
        "vendor": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "youtubeUrl": { "type": "string" },
        "price": { "type": "number" },
        "compareAtPrice": { "type": "number" },
        "costPerItem": { "type": "number" },
        "sku": { "type": "string" },
        "stockQuantity": { "type": "number" },
        "trackInventory": { "type": "boolean" },
        "continueSellingOutOfStock": { "type": "boolean" },
        "hasVariants": { "type": "boolean" },
        "variants": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "size": { "type": "string" },
              "color": { "type": "string" },
              "price": { "type": "number" },
              "sku": { "type": "string" },
              "stock": { "type": "number" },
              "image": { "type": "string" }
            }
          }
        },
        "weight": { "type": "number" },
        "isPhysical": { "type": "boolean" },
        "shippingCost": { "type": "number" },
        "seoTitle": { "type": "string" },
        "seoDescription": { "type": "string" },
        "slug": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "collections": { "type": "array", "items": { "type": "string", "enum": ["Featured", "New Arrival", "Sale"] } },
        "status": { "type": "string", "enum": ["Draft", "Active"] },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "price", "category", "status", "slug"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerPhone": { "type": "string" },
        "address": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Shipped", "Delivered"] },
        "paymentMethod": { "type": "string", "enum": ["COD"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "customerEmail", "totalAmount", "status", "paymentMethod"]
    },
    "Review": {
      "title": "Review",
      "description": "A user review for a product",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userName", "rating", "status"]
    },
    "Collection": {
      "title": "Collection",
      "description": "A product category or grouping",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "slug"]
    },
    "Page": {
      "title": "Page",
      "description": "A standard content page",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "slug": { "type": "string" },
        "seoTitle": { "type": "string" },
        "seoDescription": { "type": "string" },
        "status": { "type": "string", "enum": ["Draft", "Published"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "status"]
    },
    "StoreSettings": {
      "title": "Store Settings",
      "description": "Global store configuration",
      "type": "object",
      "properties": {
        "storeName": { "type": "string" },
        "storeDescription": { "type": "string" },
        "logoUrl": { "type": "string" },
        "faviconUrl": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store products"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews"
    },
    "/collections/{collectionId}": {
      "schema": "Collection",
      "description": "Product categories"
    },
    "/pages/{pageId}": {
      "schema": "Page",
      "description": "Content pages"
    },
    "/settings/config": {
      "schema": "StoreSettings",
      "description": "Global store settings"
    }
  }
}
